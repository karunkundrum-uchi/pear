{
  "name": "@pear/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pear/shared": "workspace:*",
    "@plasmohq/storage": "^1.15.0",
    "@supabase/supabase-js": "^2.49.4",
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.315",
    "@types/node": "^22.15.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.8.3"
  },
  "manifest": {
    "name": "Pear",
    "description": "Intentional friction for high-risk doomscrolling windows.",
    "permissions": ["storage", "tabs", "webNavigation", "activeTab", "scripting"],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_title": "Pear",
      "default_popup": "popup.html"
    }
  }
}
